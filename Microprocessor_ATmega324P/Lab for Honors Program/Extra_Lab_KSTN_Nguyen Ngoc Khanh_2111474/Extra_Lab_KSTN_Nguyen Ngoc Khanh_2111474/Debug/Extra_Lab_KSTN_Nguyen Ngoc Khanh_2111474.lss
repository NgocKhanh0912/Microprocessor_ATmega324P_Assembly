000051 ef0f                      			LDI R16, 0XFF
000052 b907                      			OUT LCD_DR, R16 ; PORTC LA OUTPORT RA LCD
000053 e000                      			LDI R16, 0X00
000054 b908                      			OUT LCD, R16 ; GIA TRI BAN DAU PORTC = 0
                                 
000055 ef0a                      			LDI R16, 250
000056 d23c                      			RCALL DELAY_128US ; CTC DELAY 128US X R16 = 32MS
000057 ef0a                      			LDI R16, 250
000058 d23a                      			RCALL DELAY_128US ; CTC DELAY 128US X R16 = 32MS
                                 
000059 9840                      			CBI LCD, RS ; RS = 0 GHI LENH
00005a e310                      			LDI R17, 0X30 ; MA LENH 30 LAN 1
00005b d11f                      			RCALL OUT_LCD4
00005c e20a                      			LDI R16, 42
00005d d235                      			RCALL DELAY_128US ; DELAY 5.376MS
                                 
00005e 9840                      			CBI LCD, RS ; RS = 0 GHI LENH
00005f e310                      			LDI R17, 0X30 ; MA LENH 30 LAN 2
000060 d11a                      			RCALL OUT_LCD4
000061 e002                      			LDI R16, 2
000062 d230                      			RCALL DELAY_128US ; DELAY 256US
                                 
000063 9840                      			CBI LCD, RS ; RS = 0 GHI LENH
000064 e310                      			LDI R17, 0X30 ; MA LENH 30 LAN 3
000065 d115                      			RCALL OUT_LCD4
000066 e002                      			LDI R16, 2
000067 d22b                      			RCALL DELAY_128US ; DELAY 256US
                                 
000068 9840                      			CBI LCD, RS ; RS = 0 GHI LENH
000069 e210                      			LDI R17, 0X20 ; MA LENH 20
00006a d110                      			RCALL OUT_LCD4
                                 
00006b e228                      			LDI R18, 0X28 ; FUNCTION SET 2 DONG FONT 5X8 MODE 4 BIT
00006c e031                      			LDI R19, 0X01 ; CLEAR DISPLAY
00006d e04c                      			LDI R20, 0X0C ; DISPLAY ON, CON TRO OFF
00006e e056                      			LDI R21, 0X06 ; ENTRY MODE SET DICH PHAI CON TRO, DDRAM TANG 1 DIA CHI
00006f d0ff                      			RCALL INIT_LCD4 ; CTC KHOI DONG LCD 4 BIT
                                 
