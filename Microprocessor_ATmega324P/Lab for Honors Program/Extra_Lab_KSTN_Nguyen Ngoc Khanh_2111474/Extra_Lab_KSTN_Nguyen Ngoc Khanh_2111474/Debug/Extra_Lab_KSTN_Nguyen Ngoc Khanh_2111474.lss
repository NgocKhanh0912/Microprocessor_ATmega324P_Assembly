000107 e230                      			LDI DATA_TRANS, 0X20 ; LAY MA ASCII CUA KI TU KHOANG TRANG
000108 d09a                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000109 e437                      			LDI DATA_TRANS, 'G' ; LAY MA ASCII CUA CHU G
00010a d098                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
00010b e439                      			LDI DATA_TRANS, 'I' ; LAY MA ASCII CUA CHU I
00010c d096                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
00010d e431                      			LDI DATA_TRANS, 'A' ; LAY MA ASCII CUA CHU A
00010e d094                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
00010f e230                      			LDI DATA_TRANS, 0X20 ; LAY MA ASCII CUA KI TU KHOANG TRANG
000110 d092                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000111 e43d                      			LDI DATA_TRANS, 'M' ; LAY MA ASCII CUA CHU M
000112 d090                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000113 e439                      			LDI DATA_TRANS, 'I' ; LAY MA ASCII CUA CHU I
000114 d08e                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000115 e534                      			LDI DATA_TRANS, 'T' ; LAY MA ASCII CUA CHU T
000116 d08c                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000117 e230                      			LDI DATA_TRANS, 0X20 ; LAY MA ASCII CUA KI TU KHOANG TRANG
000118 d08a                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000119 e43e                      			LDI DATA_TRANS, 'N' ; LAY MA ASCII CUA CHU N
00011a d088                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
00011b e43f                      			LDI DATA_TRANS, 'O' ; LAY MA ASCII CUA CHU O
00011c d086                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
00011d e43e                      			LDI DATA_TRANS, 'N' ; LAY MA ASCII CUA CHU N
00011e d084                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
00011f e33a                      			LDI DATA_TRANS, ':' ; LAY MA ASCII CUA KI TU ':'
000120 d082                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000121 e230                      			LDI DATA_TRANS, 0X20 ; LAY MA ASCII CUA KI TU KHOANG TRANG
000122 d080                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
000123 e0b2                      			LDI XH, HIGH(NHAP_DON_GIA_ADR + 12) ; X TRO VAO DIA CHI SRAM 0X264 LUU DON GIA MIT NON
000124 e6ac                      			LDI XL, LOW(NHAP_DON_GIA_ADR + 12)
                                 
000125 e004                      			LDI R16, 4 ; THANH GHI DEM, DEM DU 4 KI TU CUA DON GIA SE DUOC LUU VAO SRAM BAT DAU TU 0X264
                                 NHAP_DON_GIA_4:
000126 d083                      			RCALL USART_REC ; LAY VE MA ASCII CUA 4 KI TU CUA DON GIA THUC TE
000127 70cf                      			ANDI R28, 0X0F ; CHUYEN MA ASCII THANH BCD (VD: MA ASCII LA 0X32, ANDI DE XOA 4 BIT CAO, TRO THANH 0X02 LA SO 2 (BCD))
000128 93cd                      			ST X+, R28 ; LUU VAO DIA CHI SRAM
000129 950a                      			DEC R16 ; GIAM THANH GHI DEM DI 1 DON VI
00012a f7d9                      			BRNE NHAP_DON_GIA_4 ; QUAY LAI NEU CHUA NHAP DU 4 KI TU
                                 
00012b e03d                      			LDI DATA_TRANS, 0X0D ; LAY MA ASCII CUA KI TU XUONG DONG
00012c d076                      			RCALL USART_TRANS ; TRUYEN LEN HERCULES
                                 
                                 MAIN:
                                 			; SETTING_ADC:
00012d e40b                      			LDI R16, 0B01001011 ; VREF LA AVCC = 5V, DIF ADC1/0, X200 , HIEU CHINH PHAI
00012e 9300 007c                 			STS ADMUX, R16
                                 
000130 ea06                      			LDI R16, 0B10100110 ; CHO PHEP ADC, MODE TU KICH, F(ADC) = 125K HZ
000131 9300 007a                 			STS ADCSRA, R16
                                 
000133 e000                      			LDI R16, 0X00 ; MODE TU CHAY, NGUON TAO KICH ADIF
000134 9300 007b                 			STS ADCSRB, R16
                                 RUN_ADC:
000136 9100 007a                 			LDS R16, ADCSRA
000138 6400                      			ORI R16, (1 << ADSC) ; BAT DAU CHUYEN DOI ADC LAN DAU TIEN
000139 9300 007a                 			STS ADCSRA, R16
                                 WAIT:
00013b 9120 007a                 			LDS R18, ADCSRA ; DOC CO ADIF
00013d ff24                      			SBRS R18, ADIF ; NEU CO ADIF = 1 BAO CHUYEN DOI XONG, BO QUA LENH TIEP THEO
00013e cffc                      			RJMP WAIT
00013f 9320 007a                 			STS ADCSRA, R18 ; XOA CO ADIF
                                 
000141 91e0 0078                 			LDS R30, ADCL ; DOC ADCL TRUOC, LUU VAO R30
000143 91f0 0079                 			LDS R31, ADCH ; DOC ADCH SAU, LUU VAO R31
                                 
000145 0fee                      			LSL R30 ; NHAN 2 GIA TRI ADC VI ADC MODE VI SAI TOI DA CHI CO 512
000146 1fff                      			ROL R31 ; MUON DOC DEN 1024 THI TA X2
                                 
                                 			; (ADC X 2) DUOC LUU TRONG R31:R30
                                 			; GOI NGAN GON GIA TRI (ADC X 2) LA ADC (ADCH:ADCL), LA SO NHI PHAN 10 BIT
                                 			; GIA TRI THAP PHAN TOI DA LA 1024
                                 
                                 PHAN_LOAI_MIT:
000147 30f3                      			CPI R31, 3 ; SO SANH ADCH VOI 3
000148 f071                      			BREQ MIT_GIA ; NEU ADCH = 3 THI SO KG LUON LON HON HOAC BANG 7.68, LUON LA MIT GIA
                                 
000149 30f2                      			CPI R31, 2 ; SO SANH ADCH VOI 2
00014a f019                      			BREQ MIT_GIA_HOAC_MIT_NGON ; NEU ADCH = 2 THI SO KG LUON LON HON HOAC BANG 5.12, LA MIT GIA HOAC MIT NGON DAT CHUAN
                                 
00014b 30f1                      			CPI R31, 1 ; SO SANH ADCH VOI 1
00014c f021                      			BREQ MIT_NGON_HOAC_MIT_GAN_CHIN ; NEU ADCH = 1 THI SO KG LUON LON HON HOAC BANG 2.56, LA MIT NGON DAT CHUAN HOAC MIT GAN CHIN TOI
                                 
00014d c006                      			RJMP MIT_GAN_CHIN_HOAC_MIT_NON ; TRUONG HOP CON LAI: ADCH = 0, CO THE LA MIT NON HOAC MIT GAN CHIN TOI
                                 
                                 
                                 			; PHAN LOAI MIT GIA/MIT NGON
                                 MIT_GIA_HOAC_MIT_NGON:
00014e 35e8                      			CPI R30, 88 ; 5.12 + 0.88 = 6 KG
00014f f068                      			BRCS MIT_NGON ; NEU ADCL BE HON 88 (0.88 KG), ROI VAO TRUONG HOP MIT NGON
000150 c006                      			RJMP MIT_GIA ; NEU KHONG THI LA MIT GIA
                                 
                                 
                                 			; PHAN LOAI MIT NGON/MIT GAN CHIN
                                 MIT_NGON_HOAC_MIT_GAN_CHIN:
000151 39e0                      			CPI R30, 144 ; 2.56 + 1.44 = 4 KG
000152 f080                      			BRCS MIT_GAN_CHIN ; NEU ADCL BE HON 144 (1.44 KG), ROI VAO TRUONG HOP MIT GAN CHIN
000153 c009                      			RJMP MIT_NGON ; NEU KHONG THI LA MIT NGON
                                 
                                 
                                 			; PHAN LOAI MIT GAN CHIN/MIT NON
                                 MIT_GAN_CHIN_HOAC_MIT_NON:
000154 3ce8                      			CPI R30, 200 ; 2 KG
000155 f098                      			BRCS MIT_NON ; NEU ADCL BE HON 200 (2 KG), ROI VAO TRUONG HOP MIT NON
000156 c00c                      			RJMP MIT_GAN_CHIN ; NEU KHONG THI LA MIT GAN CHIN
                                 
                                 ;------------------------------------------------------------------------------------------------------------------------------
                                 MIT_GIA:
000157 d0bf                      			RCALL LAY_BCD_SO_KG ; LAY SO BCD GIA TRI KG
                                 
000158 d058                      			RCALL TINH_DON_GIA_MIT_GIA ; TINH GIA TRI THANH GHI DON_GIA = (DON GIA THUC TE X10), DON GIA THUC TE DUOC NHAP TU HERCULES
000159 d093                      			RCALL LAY_BCD_DON_GIA ; LAY SO BCD CUA DON GIA
                                 
00015a d0e3                      			RCALL TINH_TIEN ; TINH GIA TRI GIA_TIEN LA SO BINARY 24 BIT, SO BCD 6 DIGIT
00015b d0ef                      			RCALL LAY_BCD_GIA_TIEN ; LAY SO BCD GIA MIT
                                 
00015c cfd0                      			RJMP MAIN
                                 
                                 MIT_NGON:
00015d d0b9                      			RCALL LAY_BCD_SO_KG ; LAY SO BCD GIA TRI KG
                                 
00015e d061                      			RCALL TINH_DON_GIA_MIT_NGON ; TINH GIA TRI THANH GHI DON_GIA = (DON GIA THUC TE X10), DON GIA THUC TE DUOC NHAP TU HERCULES
00015f d08d                      			RCALL LAY_BCD_DON_GIA ; LAY SO BCD CUA DON GIA
                                 
000160 d0dd                      			RCALL TINH_TIEN ; TINH GIA TRI GIA_TIEN LA SO BINARY 24 BIT, SO BCD 6 DIGIT
000161 d0e9                      			RCALL LAY_BCD_GIA_TIEN ; LAY SO BCD GIA MIT
                                 
000162 cfca                      			RJMP MAIN
                                 
                                 MIT_GAN_CHIN:
000163 d0b3                      			RCALL LAY_BCD_SO_KG ; LAY SO BCD GIA TRI KG
                                 
000164 d06a                      			RCALL TINH_DON_GIA_MIT_GAN_CHIN ; TINH GIA TRI THANH GHI DON_GIA = (DON GIA THUC TE X10), DON GIA THUC TE DUOC NHAP TU HERCULES
000165 d087                      			RCALL LAY_BCD_DON_GIA ; LAY SO BCD CUA DON GIA
                                 
000166 d0d7                      			RCALL TINH_TIEN ; TINH GIA TRI GIA_TIEN LA SO BINARY 24 BIT, SO BCD 6 DIGIT
000167 d0e3                      			RCALL LAY_BCD_GIA_TIEN ; LAY SO BCD GIA MIT
                                 
000168 cfc4                      			RJMP MAIN
                                 
                                 MIT_NON:
000169 d0ad                      			RCALL LAY_BCD_SO_KG ; LAY SO BCD GIA TRI KG
                                 
00016a d073                      			RCALL TINH_DON_GIA_MIT_NON ; TINH GIA TRI THANH GHI DON_GIA = (DON GIA THUC TE X10), DON GIA THUC TE DUOC NHAP TU HERCULES
00016b d081                      			RCALL LAY_BCD_DON_GIA ; LAY SO BCD CUA DON GIA
                                 
00016c d0d1                      			RCALL TINH_TIEN ; TINH GIA TRI GIA_TIEN LA SO BINARY 24 BIT, SO BCD 6 DIGIT
00016d d0dd                      			RCALL LAY_BCD_GIA_TIEN ; LAY SO BCD GIA MIT
                                 
00016e cfbe                      			RJMP MAIN
                                 
                                 ;---------------------------------------------------------------------------------------------------------------------------------------
                                 ; INIT_LCD4 KHOI DONG LCD GHI 4 BYTE MA LENH THEO GIAO TIEP 4 BIT
                                 ; FUNCTION SET R18 = 0X28 2 DONG FONT 5X8 GIAO TIEP 4 BIT
                                 ; CLEAR DISPLAY R19 = 0X01 XOA MAN HINH
                                 ; DISPLAY ON/OFF CONTROL R20 = 0X0C MAN HINH ON, CON TRO OFF
                                 ; ENTRY MODE SET R21 = 0X06 DICH PHAI CON TRO , DC DDRAM TANG LEN 1 DVI
                                 
                                 INIT_LCD4:
00016f 9840                      			CBI LCD, RS ; GHI LENH
000170 2f12                      			MOV R17, R18 ; FUNCTION SET
000171 d00d                      			RCALL OUT_LCD ; GHI RA LCD
                                 
000172 2f13                      			MOV R17, R19 ; CLEAR DISPLAY
000173 d00b                      			RCALL OUT_LCD ; GHI RA LCD
                                 
000174 e104                      			LDI R16, 20
000175 d11d                      			RCALL DELAY_128US ; DELAY 2.56 MS
                                 
000176 2f14                      			MOV R17, R20 ; DISPLAY ON/OFF CONTROL
000177 d007                      			RCALL OUT_LCD ; GHI RA LCD
                                 
000178 2f15                      			MOV R17, R21 ; ENTRY MODE SET
000179 d005                      			RCALL OUT_LCD ; GHI RA LCD
                                 
00017a 9508                      			RET
                                 
                                 
                                 ;--------------------------------------------------------
                                 ; OUT LCD4 GHI MA LENH/ DATA RA LCD
                                 ; INPUT R17 CHUA MA LENH/ DATA 4 BIT CAO
                                 
                                 OUT_LCD4:
00017b b918                      			OUT LCD, R17
00017c 9a42                      			SBI LCD, E
00017d 9842                      			CBI LCD, E
                                 
00017e 9508                      			RET
                                 
                                 ;------------------------------------------------------------
                                 ; OUT_LCD GHI 1 BYTE MA LENH/DATA RA LCD
                                 ; CHIA LAM 2 LAN GHI 4 BIT
                                 ; INPUT R17 CHUA MA LENH/DATA
                                 ; RS = 0/1 LENH/DATA
                                 ; RW = 0 GHI
                                 ; SU DUNG OUT_LCD4
                                 
                                 OUT_LCD:
00017f e001                      			LDI R16, 1
000180 d112                      			RCALL DELAY_128US
                                 
000181 b108                      			IN R16, LCD ; DOC PORT LCD
000182 7001                      			ANDI R16, (1 << RS) ; LOC BIT RS
                                 
000183 930f                      			PUSH R16 ; LUU TRU R16
000184 931f                      			PUSH R17 ; LUU TRU R17
                                 
000185 7f10                      			ANDI R17, 0XF0 ; LAY 4 BIT CAO
000186 2b10                      			OR R17, R16 ; GHEP BIT RS
000187 dff3                      			RCALL OUT_LCD4 ; GHI RA LCD
                                 
000188 e001                      			LDI R16, 1
000189 d109                      			RCALL DELAY_128US
                                 
00018a 911f                      			POP R17
00018b 910f                      			POP R16
                                 
00018c 9512                      			SWAP R17 ; SWAP 2 NIBBLE
00018d 7f10                      			ANDI R17, 0XF0 ; LAY 4 BIT THAP CHUYEN THANH CAO
00018e 2b10                      			OR R17, R16 ; GHEP BIT RS
00018f dfeb                      			RCALL OUT_LCD4 ; GHI RA LCD
                                 
000190 9508                      			RET
                                 
                                 ;-----------------------------------------------------------------------------------------
                                 ; CURS_POS DAT CON TRO VI TRI LCD TAI DIA CHI CO TRONG R17
                                 
                                 CURS_POS:
000191 e001                      			LDI R16, 1
000192 d100                      			RCALL DELAY_128US
000193 9840                      			CBI LCD, RS ; GHI LENH
000194 dfea                      			RCALL OUT_LCD
                                 
000195 9508                      			RET
                                 
                                 ;---------------------------------------------------------------------------------------------
                                 ; KHOI DONG BO USART
                                 
                                 USART_INIT:
000196 e108                      			LDI R16, (1 << TXEN0)|(1 << RXEN0); CHO PHEP BO PHAT VA BO THU
000197 9300 00c1                 			STS UCSR0B, R16
                                 
000199 e006                      			LDI R16, (1 << UCSZ01)|(1 << UCSZ00) ; 8 BIT DATA/KHONG KT CHAN LE/1 STOP BIT
00019a 9300 00c2                 			STS UCSR0C, R16
                                 
00019c e000                      			LDI R16, 0
00019d 9300 00c5                 			STS UBRR0H, R16
00019f e303                      			LDI R16, 51 ; BAUD RATE = 9600 UNG VOI FOSC = 8MHZ
0001a0 9300 00c4                 			STS UBRR0L, R16
                                 
0001a2 9508                      			RET
                                 
                                 ;-------------------------------------------------------------------------------------------------------------------------------------
                                 ; TRUYEN KI TU CO TRONG THANH GHI DATA_TRANS LEN HERCULES
                                 
                                 USART_TRANS:
0001a3 9110 00c0                 			LDS R17, UCSR0A
0001a5 ff15                      			SBRS R17, UDRE0 ; KIEM TRA UDR0 CO TRONG KHONG (UDRE0 = 1?)
0001a6 cffc                      			RJMP USART_TRANS
0001a7 9330 00c6                 			STS UDR0, DATA_TRANS ; KHI UDR0 TRONG THI CHEP DU LIEU TU DATA_TRANS CHUA THANH GHI CAN XUAT VAO UDR0
                                 
0001a9 9508                      			RET
                                 
                                 ;-------------------------------------------------------------------------------------------------------------------------------------
                                 ; NHAN KI TU TU HERCULES XUONG THANH GHI R28 (DATA_REC)
                                 
                                 USART_REC:
                                 			; R28 LA DATA_REC
0001aa 9110 00c0                 			LDS R17, UCSR0A
0001ac ff17                      			SBRS R17, RXC0
0001ad cffc                      			RJMP USART_REC
0001ae 91c0 00c6                 			LDS R28, UDR0 ; NAP DU LIEU TU UDR0 VAO DATA_REC (R28)
                                 
0001b0 9508                      			RET
                                 
                                 
                                 ;----------------------------------------------------------------------------------------------------
                                 
                                 TINH_DON_GIA_MIT_GIA:
                                 ; CHUONG TRINH CON TINH GIA TRI CUA THANH GHI DON_GIA = (DON GIA THUC TE X10) CUA MIT GIA
                                 
                                 ; 4 KI TU CUA DON GIA THUC TE CUA MIT GIA DUOC LUU O DIA CHI SRAM TU 0X260 DEN 0X263
                                 ; VD: KHI NGUOI DUNG NHAP VAO "12.5" THI:
                                 ; '1' DUOC LUU O 0X260, LA BCD HANG TRAM CUA THANH GHI DON_GIA
                                 ; '2' DUOC LUU O 0X261, LA BCD HANG CHUC CUA THANH GHI DON_GIA
                                 ; '.' DUOC LUU O 0X262, LA DAU CHAM THAP PHAN
                                 ; '5' DUOC LUU O 0X263, LA BCD HANG DON VI CUA THANH GHI DON GIA
                                 
                                 ; TINH GIA TRI THANH GHI DON_GIA BANG CACH LAY:
                                 ; (BCD HANG TRAM)x100 + (BCD HANG CHUC)x10 + (BCD HANG DON VI) -> THANH GHI DON_GIA
                                 ; BO QUA DAU CHAM THAP PHAN
                                 
0001b1 e0b2                      			LDI XH, HIGH(NHAP_DON_GIA_ADR) ; X TRO VAO 0X260
0001b2 e6a0                      			LDI XL, LOW(NHAP_DON_GIA_ADR)
0001b3 2722                      			CLR DON_GIA ; CLEAR THANH GHI DON GIA TRUOC KHI SU DUNG
                                 
0001b4 910d                      			LD R16, X+ ; LAY BCD HANG TRAM
0001b5 e614                      			LDI R17, 100
0001b6 9f01                      			MUL R16, R17 ; NHAN BCD HANG TRAM CHO 100, KET QUA CHUA TRONG R0
0001b7 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI_DON GIA VOI R0
                                 
0001b8 910d                      			LD R16, X+ ; LAY BCD HANG CHUC
0001b9 e01a                      			LDI R17, 10
0001ba 9f01                      			MUL R16, R17 ; NHAN BCD HANG CHUC CHO 10, KET QUA CHUA TRONG R0
0001bb 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI DON_GIA VOI R0
                                 
0001bc 910d                      			LD R16, X+ ; X LUC NAY TRO VAO DIA CHIA SRAM CUA DAU CHAM THAP PHAN, TA BO QUA
                                 
0001bd 910d                      			LD R16, X+ ; LAY BCD HANG DON VI
0001be 0f20                      			ADD DON_GIA, R16 ; CONG THANH GHI DON_GIA VOI BCD HANG DON VI
                                 
0001bf 9508                      			RET
                                 
                                 ;----------------------------------------------------------------------------------------------------
                                 
                                 TINH_DON_GIA_MIT_NGON:
                                 ; CHUONG TRINH CON TINH GIA TRI CUA THANH GHI DON_GIA = (DON GIA THUC TE X10) CUA MIT NGON
                                 
                                 ; 4 KI TU CUA DON GIA THUC TE CUA MIT NGON DUOC LUU O DIA CHI SRAM TU 0X264 DEN 0X267
                                 ; VD: KHI NGUOI DUNG NHAP VAO "12.5" THI:
                                 ; '1' DUOC LUU O 0X264, LA BCD HANG TRAM CUA THANH GHI DON_GIA
                                 ; '2' DUOC LUU O 0X265, LA BCD HANG CHUC CUA THANH GHI DON_GIA
                                 ; '.' DUOC LUU O 0X266, LA DAU CHAM THAP PHAN
                                 ; '5' DUOC LUU O 0X267, LA BCD HANG DON VI CUA THANH GHI DON GIA
                                 
                                 ; TINH GIA TRI THANH GHI DON_GIA BANG CACH LAY:
                                 ; (BCD HANG TRAM)x100 + (BCD HANG CHUC)x10 + (BCD HANG DON VI) -> THANH GHI DON_GIA
                                 ; BO QUA DAU CHAM THAP PHAN
                                 
0001c0 e0b2                      			LDI XH, HIGH(NHAP_DON_GIA_ADR + 4) ; X TRO VAO 0X264
0001c1 e6a4                      			LDI XL, LOW(NHAP_DON_GIA_ADR + 4)
0001c2 2722                      			CLR DON_GIA ; CLEAR THANH GHI DON GIA TRUOC KHI SU DUNG
                                 
0001c3 910d                      			LD R16, X+ ; LAY BCD HANG TRAM
0001c4 e614                      			LDI R17, 100
0001c5 9f01                      			MUL R16, R17 ; NHAN BCD HANG TRAM CHO 100, KET QUA CHUA TRONG R0
0001c6 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI_DON GIA VOI R0
                                 
0001c7 910d                      			LD R16, X+ ; LAY BCD HANG CHUC
0001c8 e01a                      			LDI R17, 10
0001c9 9f01                      			MUL R16, R17 ; NHAN BCD HANG CHUC CHO 10, KET QUA CHUA TRONG R0
0001ca 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI DON_GIA VOI R0
                                 
0001cb 910d                      			LD R16, X+ ; X LUC NAY TRO VAO DIA CHIA SRAM CUA DAU CHAM THAP PHAN, TA BO QUA
                                 
0001cc 910d                      			LD R16, X+ ; LAY BCD HANG DON VI
0001cd 0f20                      			ADD DON_GIA, R16 ; CONG THANH GHI DON_GIA VOI BCD HANG DON VI
                                 
0001ce 9508                      			RET
                                 
                                 
                                 ;----------------------------------------------------------------------------------------------------
                                 
                                 TINH_DON_GIA_MIT_GAN_CHIN:
                                 ; CHUONG TRINH CON TINH GIA TRI CUA THANH GHI DON_GIA = (DON GIA THUC TE X10) CUA MIT GAN CHIN
                                 
                                 ; 4 KI TU CUA DON GIA THUC TE CUA MIT GAN CHIN DUOC LUU O DIA CHI SRAM TU 0X268 DEN 0X26B
                                 ; VD: KHI NGUOI DUNG NHAP VAO "12.5" THI:
                                 ; '1' DUOC LUU O 0X268, LA BCD HANG TRAM CUA THANH GHI DON_GIA
                                 ; '2' DUOC LUU O 0X269, LA BCD HANG CHUC CUA THANH GHI DON_GIA
                                 ; '.' DUOC LUU O 0X26A, LA DAU CHAM THAP PHAN
                                 ; '5' DUOC LUU O 0X26B, LA BCD HANG DON VI CUA THANH GHI DON GIA
                                 
                                 ; TINH GIA TRI THANH GHI DON_GIA BANG CACH LAY:
                                 ; (BCD HANG TRAM)x100 + (BCD HANG CHUC)x10 + (BCD HANG DON VI) -> THANH GHI DON_GIA
                                 ; BO QUA DAU CHAM THAP PHAN
                                 
0001cf e0b2                      			LDI XH, HIGH(NHAP_DON_GIA_ADR + 8) ; X TRO VAO 0X268
0001d0 e6a8                      			LDI XL, LOW(NHAP_DON_GIA_ADR + 8)
0001d1 2722                      			CLR DON_GIA ; CLEAR THANH GHI DON GIA TRUOC KHI SU DUNG
                                 
0001d2 910d                      			LD R16, X+ ; LAY BCD HANG TRAM
0001d3 e614                      			LDI R17, 100
0001d4 9f01                      			MUL R16, R17 ; NHAN BCD HANG TRAM CHO 100, KET QUA CHUA TRONG R0
0001d5 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI_DON GIA VOI R0
                                 
0001d6 910d                      			LD R16, X+ ; LAY BCD HANG CHUC
0001d7 e01a                      			LDI R17, 10
0001d8 9f01                      			MUL R16, R17 ; NHAN BCD HANG CHUC CHO 10, KET QUA CHUA TRONG R0
0001d9 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI DON_GIA VOI R0
                                 
0001da 910d                      			LD R16, X+ ; X LUC NAY TRO VAO DIA CHIA SRAM CUA DAU CHAM THAP PHAN, TA BO QUA
                                 
0001db 910d                      			LD R16, X+ ; LAY BCD HANG DON VI
0001dc 0f20                      			ADD DON_GIA, R16 ; CONG THANH GHI DON_GIA VOI BCD HANG DON VI
                                 
0001dd 9508                      			RET
                                 
                                 
                                 ;----------------------------------------------------------------------------------------------------
                                 
                                 TINH_DON_GIA_MIT_NON:
                                 ; CHUONG TRINH CON TINH GIA TRI CUA THANH GHI DON_GIA = (DON GIA THUC TE X10) CUA MIT NON
                                 
                                 ; 4 KI TU CUA DON GIA THUC TE CUA MIT NON DUOC LUU O DIA CHI SRAM TU 0X26C DEN 0X26F
                                 ; VD: KHI NGUOI DUNG NHAP VAO "12.5" THI:
                                 ; '1' DUOC LUU O 0X26C, LA BCD HANG TRAM CUA THANH GHI DON_GIA
                                 ; '2' DUOC LUU O 0X26D, LA BCD HANG CHUC CUA THANH GHI DON_GIA
                                 ; '.' DUOC LUU O 0X26E, LA DAU CHAM THAP PHAN
                                 ; '5' DUOC LUU O 0X26F, LA BCD HANG DON VI CUA THANH GHI DON GIA
                                 
                                 ; TINH GIA TRI THANH GHI DON_GIA BANG CACH LAY:
                                 ; (BCD HANG TRAM)x100 + (BCD HANG CHUC)x10 + (BCD HANG DON VI) -> THANH GHI DON_GIA
                                 ; BO QUA DAU CHAM THAP PHAN
                                 
0001de e0b2                      			LDI XH, HIGH(NHAP_DON_GIA_ADR + 12) ; X TRO VAO 0X26C
0001df e6ac                      			LDI XL, LOW(NHAP_DON_GIA_ADR + 12)
0001e0 2722                      			CLR DON_GIA ; CLEAR THANH GHI DON GIA TRUOC KHI SU DUNG
                                 
0001e1 910d                      			LD R16, X+ ; LAY BCD HANG TRAM
0001e2 e614                      			LDI R17, 100
0001e3 9f01                      			MUL R16, R17 ; NHAN BCD HANG TRAM CHO 100, KET QUA CHUA TRONG R0
0001e4 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI_DON GIA VOI R0
                                 
0001e5 910d                      			LD R16, X+ ; LAY BCD HANG CHUC
0001e6 e01a                      			LDI R17, 10
0001e7 9f01                      			MUL R16, R17 ; NHAN BCD HANG CHUC CHO 10, KET QUA CHUA TRONG R0
0001e8 0d20                      			ADD DON_GIA, R0 ; CONG THANH GHI DON_GIA VOI R0
                                 
0001e9 910d                      			LD R16, X+ ; X LUC NAY TRO VAO DIA CHIA SRAM CUA DAU CHAM THAP PHAN, TA BO QUA
                                 
0001ea 910d                      			LD R16, X+ ; LAY BCD HANG DON VI
0001eb 0f20                      			ADD DON_GIA, R16 ; CONG THANH GHI DON_GIA VOI BCD HANG DON VI
                                 
0001ec 9508                      			RET
                                 
                                 
                                 ; -----------------------------------------------------------------------------------------------------------------------------------------
                                 ; LAY_BCD_DON_GIA CHUYEN SO NHI PHAN 8 BIT (DON_GIA) SANG SO BCD 3 DIGIT
                                 ; SAU DO CHUYEN CAC SO BCD NAY THANH MA ASCII TUONG UNG
                                 ; LUU DONG CHU: EF.G USD/KG VA KI TU KET THUC (0X00) VAO DIA CHI SRAM TU 0X20B DEN 0X200
                                 ; VOI EF.G LA DON GIA THUC TE
                                 
                                 ; INPUT: DON_GIA = SO NHI PHAN 8 BIT
                                 ; OUTPUT: LUU MA ASCII CUA CAC SO BCD CUA DON_GIA VA DONG CHU "USD/KG" VA KI TU KET THUC (0X00) VAO CAC O DIA CHI BAT DAU TU USD_PER_KG_ADR (0X200)
                                 ; DAT DAU CHAM (.) THAP PHAN VAO DUNG VI TRI DE RA DUOC DON GIA MIT THUC TE
                                 
                                 ; SU DUNG CTC DIV2 , SO CHIA = 10
                                 
                                 LAY_BCD_DON_GIA:
0001ed 932f                      			PUSH DON_GIA ; BAO TOAN GIA TRI DON_GIA DE SU DUNG TIEP TINH GIA TIEN
                                 
0001ee e0b2                      			LDI XH, HIGH(USD_PER_KG_ADR) ; X TRO VAO DIA CHI SRAM USD_PER_KG_ADR LUU MA ASCII CUA CAC BCD CUA DON GIA
0001ef e0a0                      			LDI XL, LOW(USD_PER_KG_ADR)
                                 
0001f0 e000                      			LDI R16, 0X00
0001f1 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU KET THUC (LINE 2 LCD) VAO USD_PER_KG_ADR (0X200)
                                 
0001f2 e407                      			LDI R16, 'G'
0001f3 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU G VAO USD_PER_KG_ADR + 1 (0X201)
                                 
0001f4 e40b                      			LDI R16, 'K'
0001f5 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU K VAO USD_PER_KG_ADR + 2 (0X202)
                                 
0001f6 e20f                      			LDI R16, '/'
0001f7 930d                      			ST X+, R16 ; LUU MA ASCII CUA DAU '/' VAO USD_PER_KG_ADR +3 (0X203)
                                 
0001f8 e404                      			LDI R16, 'D'
0001f9 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU D VAO USD_PER_KG_ADR + 4 (0X204)
                                 
0001fa e503                      			LDI R16, 'S'
0001fb 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU S VAO USD_PER_KG_ADR + 5 (0X205)
                                 
0001fc e505                      			LDI R16, 'U'
0001fd 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU U VAO USD_PER_KG_ADR + 6 (0X206)
                                 
0001fe e200                      			LDI R16, 0X20
0001ff 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU KHOANG TRANG VAO USD_PER_KG_ADR + 7 (0X207)
                                 
000200 d00c                      			RCALL DIV2
000201 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG DON VI THANH MA ASCII
000202 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD DON VI VAO USD_PER_KG_ADR + 8 (0X208)
                                 
000203 e20e                      			LDI R16, '.' ; LAY MA ASCII CUA DAU CHAM THAP PHAN
000204 930d                      			ST X+, R16 ; LUU VAO USD_PER_KG_ADR + 9 (0X209)
                                 
000205 d007                      			RCALL DIV2
000206 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG CHUC THANH MA ASCII
000207 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG CHUC VAO USD_PER_KG_ADR + 10 (0X20A)
                                 
000208 d004                      			RCALL DIV2
000209 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG TRAM THANH MA ASCII
00020a 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG TRAM VAO USD_PER_KG_ADR + 11 (0X20B)
                                 
                                 			; DIA CHI SRAM TU 0X20B DEN 0X200 SE LUU "EF.G USD/KG" VA KI TU 0X00 (KET THUC) VOI EF.G LA DON GIA CUA TUNG LOAI MIT
                                 
00020b 912f                      			POP DON_GIA
                                 
00020c 9508                      			RET
                                 
                                 
                                 
                                 ;--------------------------------------------------------------
                                 ; DIV2 CHIA SO NHI PHAN 8 BIT (DON_GIA) CHO 8 BIT (10)
                                 ; CHIA BANG CACH TRU NHIEU LAN CHO SO CHIA
                                 
                                 ; INPUT: DON_GIA LA SO BI CHIA, SO CHIA = 10
                                 ; OUTPUT: DON_GIA LA THUONG SO, R16 LA DU SO
                                 
                                 ; SD R28 DE CAT THUONG SO TAM
                                 
                                 DIV2:
00020d 27cc                      			CLR R28
00020e e0da                      			LDI R29, 10
                                 GT_DV2:
00020f 502a                      			SUBI DON_GIA, 10
000210 f010                      			BRCS LT_DV2 ; C = 1 KHONG CHIA DUOC
000211 95c3                      			INC R28
000212 cffc                      			RJMP GT_DV2
                                 LT_DV2:
000213 0f2d                      			ADD DON_GIA, R29 ; LAY LAI DU SO
000214 2f02                      			MOV R16, DON_GIA ; R16 = DU SO
000215 2f2c                      			MOV DON_GIA, R28 ; GIA_CO_DINH = THUONG SO
                                 
000216 9508                      			RET
                                 
                                 
                                 
                                 ; ------------------------------------------------------------------------------------------------------------------------------------
                                 ; LAY_BCD_SO_KG CHUYEN SO NHI PHAN 12 BIT (ADC X 2, HAY GOI NGAN GON LA ADC) SANG SO BCD 4 DIGIT
                                 ; SAU DO CHUYEN CAC SO BCD NAY THANH MA ASCII TUONG UNG
                                 ; LUU DONG CHU: AB.CD KG VA KI TU XUONG DONG (0X0D) VAO DIA CHI SRAM TU 0X214 DEN 0X20C
                                 ; VOI AB.CD LA SO KG THUC TE
                                 
                                 ; INPUT: ADC_HIGH:ADC_LOW = SO NHI PHAN 16 BIT
                                 ; OUTPUT: LUU MA ASCII CUA CAC SO BCD CUA SO KG VA DONG CHU "KG" VA KI TU XUONG DONG (0X0D) VAO CAC O DIA CHI BAT DAU TU KG_ADR (0X20C)
                                 ; DAT DAU CHAM (.) THAP PHAN VAO DUNG VI TRI DE RA DUOC SO KG
                                 
                                 ; SU DUNG CTC DIV1 , SO CHIA = 10
                                 
                                 LAY_BCD_SO_KG:
000217 93ef                      			PUSH R30
000218 93ff                      			PUSH R31 ; BAO TOAN GIA TRI ADC DE SU DUNG TIEP TINH GIA TIEN
                                 
000219 e0b2                      			LDI XH, HIGH(KG_ADR) ; X TRO VAO DIA CHI SRAM KG_ADR LUU MA ASCII CUA CAC BCD CUA SO KG
00021a e0ac                      			LDI XL, LOW(KG_ADR)
                                 
00021b e00d                      			LDI R16, 0X0D
00021c 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU XUONG DONG DE NHAN BIET KET THUC DONG 1 LCD VAO KG_ADR (0X20C)
                                 
00021d e407                      			LDI R16, 'G'
00021e 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU G VAO KG_ADR + 1 (0X20D)
                                 
00021f e40b                      			LDI R16, 'K'
000220 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU K VAO KG_ADR + 2 (0X20E)
                                 
000221 e200                      			LDI R16, 0X20
000222 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU KHOANG TRANG VAO KG_ADR + 3 (0X20F)
                                 
000223 d010                      			RCALL DIV1
000224 6300                      			ORI R16, 0X30 ; CHUYEN BCD DON VI THANH MA ASCII
000225 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD DON VI VAO KG_ADR + 4 (0X210)
                                 
000226 d00d                      			RCALL DIV1
000227 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG CHUC THANH MA ASCII
000228 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG CHUC VAO KG_ADR + 5 (0X211)
                                 
000229 e20e                      			LDI R16, '.' ; LAY MA ASCII CUA DAU CHAM THAP PHAN
00022a 930d                      			ST X+, R16 ; LUU VAO KG_ADR + 6 (0X212)
                                 
00022b d008                      			RCALL DIV1
00022c 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG TRAM THANH MA ASCII
00022d 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG TRAM VAO KG_ADR + 7 (0X213)
                                 
00022e d005                      			RCALL DIV1
00022f 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG NGHIN THANH MA ASCII
000230 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG NGHIN VAO KG_ADR + 8 (0X214)
                                 
                                 			; DIA CHI SRAM TU 0X214 DEN 0X20C SE LUU "AB.CD KG" VA KI TU 0X0D (XUONG DONG) VOI AB.CD LA SO KG DOC DUOC TU BO ADC
                                 
000231 91ff                      			POP R31
000232 91ef                      			POP R30 ; POP THEO QUY TAC LAST IN FIRST OUT
                                 
000233 9508                      			RET
                                 
                                 ;--------------------------------------------------------------------------------------------------------------------
                                 ; DIV1 CHIA SO NHI PHAN 12 BIT (ADC) CHO 8 BIT (10)
                                 ; CHIA BANG CACH TRU NHIEU LAN CHO SO CHIA
                                 
                                 ; INPUT: ADC_HIGH:ADC_LOW LA SO BI CHIA, SO CHIA = 10
                                 ; OUTPUT: ADC_HIGH:ADC_LOW LA THUONG SO, R16 LA DU SO
                                 
                                 ; SD R28:R29 DE CAT THUONG SO TAM
                                 
                                 DIV1:
000234 27cc                      			CLR R28
000235 27dd                      			CLR R29
                                 GT_DV1:
000236 973a                      			SBIW R30, 10
000237 f010                      			BRCS LT_DV1 ; C = 1 KHONG CHIA DUOC
000238 9621                      			ADIW R28, 1
000239 cffc                      			RJMP GT_DV1
                                 LT_DV1:
00023a 963a                      			ADIW R30, 10 ; LAY LAI DU SO
00023b 2f0e                      			MOV R16, R30 ; R16 = DU SO
00023c 01fe                      			MOVW R30, R28 ; ADC_HIGH:ADC_LOW = THUONG SO
                                 
00023d 9508                      			RET
                                 
                                 
                                 
                                 
                                 ;-------------------------------------------------------------------------------------------------------------
                                 ; TINH_TIEN: NHAN SO NHI PHAN 12 BIT (ADC X 2, HAY GOI NGAN GON LA ADC) CHO 8 BIT (DON_GIA), KET QUA 24 BIT
                                 ; NHAN BANG CACH CONG ADC CHO CHINH NO (DON_GIA) LAN
                                 
                                 ; INPUT: ADC_HIGH:ADC_LOW (R31:R30) LA SO BI NHAN 12 BIT, DON_GIA LA SO NHAN 8 BIT
                                 ; OUTPUT: GIA_TIEN_HIGH:GIA_TIEN_MIDDLE:GIA_TIEN_LOW
                                 
                                 ; SU DUNG R2, R3, R4, R17 LAM CAC THANH GHI TAM THOI
                                 
                                 TINH_TIEN:
00023e 2422                      			CLR R2
00023f 2433                      			CLR R3
000240 2444                      			CLR R4 ; CLEAR CAC THANH GHI TAM THOI
                                 MULTI:
000241 e050                      			LDI R21, 0
000242 0e2e                      			ADD R2, R30 ; CONG LIEN TIEP R2 VOI ADCL
000243 1e3f                      			ADC R3, R31 ; CONG LIEN TIEP R3 VOI ADCH VA CARRY (NEU CO)
000244 1e45                      			ADC R4, R21 ; CONG LIEN TIEP R4 VOI CARRY (NEU CO)
000245 952a                      			DEC DON_GIA ; DON_GIA DONG VAI TRO LA SO DEM
000246 f7d1                      			BRNE MULTI
                                 
000247 2d72                      			MOV GIA_TIEN_LOW, R2
000248 2d83                      			MOV GIA_TIEN_MIDDLE, R3
000249 2d94                      			MOV GIA_TIEN_HIGH, R4 ; CHUYEN CAC GIA TRI TRONG R4:R3:R2 SANG 3 THANH GHI GIA_TIEN
                                 
00024a 9508                      			RET
                                 
                                 
                                 ; ----------------------------------------------------------------------------------------------------------------------------------------------
                                 ; LAY_BCD_GIA_TIEN CHUYEN SO NHI PHAN 24 BIT (GIA_TIEN_HIGH:GIA_TIEN_MIDDLE:GIA_TIEN_LOW) SANG SO BCD 6 DIGIT
                                 ; SAU DO CHUYEN CAC SO BCD NAY THANH MA ASCII TUONG UNG
                                 
                                 ; INPUT: GIA_TIEN_HIGH:GIA_TIEN_MIDDLE:GIA_TIEN_LOW = SO NHI PHAN 24 BIT
                                 ; OUTPUT: LUU MA ASCII CUA CAC SO BCD CUA GIA_TIEN(HIGH:MIDDLE:LOW) VA CAC KI TU ASCII KHAC VAO CAC O DIA CHI BAT DAU TU PAY_ADR DE XUAT RA LCD
                                 ; DAT DAU CHAM (.) THAP PHAN VAO DUNG VI TRI DE RA DUOC GIA TIEN THUC TE
                                 
                                 ; SU DUNG CTC DIV3 , SO CHIA = 10
                                 
                                 LAY_BCD_GIA_TIEN:
                                 
00024b e0b2                      			LDI XH, HIGH(PAY_ADR) ; X TRO VAO DIA CHI SRAM PAY_ADR LUU MA ASCII CUA CAC BCD CUA GIA TIEN CUOI CUNG
00024c e4a0                      			LDI XL, LOW(PAY_ADR)
                                 
00024d e000                      			LDI R16, 0X00
00024e 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU KET THUC (LINE 2 LCD) VAO PAY_ADR (0X240)
                                 
00024f d02a                      			RCALL DIV3
000250 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG DON VI THANH MA ASCII
000251 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD DON VI VAO PAY_ADR + 1 (0X241)
                                 
000252 d027                      			RCALL DIV3
000253 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG CHUC THANH MA ASCII
000254 930d                      			ST X+, R16 ; LUU ASCII CUA BCD HANG CHUC VAO PAY_ADR + 2 (0X242)
                                 
000255 d024                      			RCALL DIV3
000256 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG CHUC THANH MA ASCII
000257 930d                      			ST X+, R16 ; LUU ASCII CUA BCD HANG TRAM VAO PAY_ADR + 3 (0X243)
                                 
000258 e20e                      			LDI R16, '.' ; LAY MA ASCII CUA DAU CHAM THAP PHAN
000259 930d                      			ST X+, R16 ; LUU VAO PAY_ADR + 4 (0X244)
                                 
00025a d01f                      			RCALL DIV3
00025b 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG TRAM THANH MA ASCII
00025c 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG NGHIN VAO PAY_ADR + 5 (0X245)
                                 
00025d d01c                      			RCALL DIV3
00025e 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG NGHIN THANH MA ASCII
00025f 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG CHUC NGHIN VAO PAY_ADR + 6 (0X246)
                                 
000260 d019                      			RCALL DIV3
000261 6300                      			ORI R16, 0X30 ; CHUYEN BCD HANG CHUC NGHIN THANH MA ASCII
000262 930d                      			ST X+, R16 ; LUU MA ASCII CUA BCD HANG TRAM NGHIN VAO PAY_ADR + 7 (0X247)
                                 
000263 e00d                      			LDI R16, 0X0D
000264 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU XUONG DONG DE BIET KET THUC DONG 1 VAO PAY_ADR + 8 (0X248)
                                 
000265 e40e                      			LDI R16, 'N'
000266 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU N VAO PAY_ADR + 9 (0X249)
                                 
000267 e405                      			LDI R16, 'E'
000268 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU E VAO PAY_ADR + 10 (0X24A)
                                 
000269 e409                      			LDI R16, 'I'
00026a 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU I VAO PAY_ADR + 11 (0X24B)
                                 
00026b e504                      			LDI R16, 'T'
00026c 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU T VAO PAY_ADR + 12 (0X24C)
                                 
00026d e200                      			LDI R16, 0X20
00026e 930d                      			ST X+, R16 ; LUU MA ASCII CUA KI TU KHOANG TRANG VAO PAY_ADR + 13 (0X24D)
                                 
00026f e408                      			LDI R16, 'H'
000270 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU H VAO PAY_ADR + 14 (0X24E)
                                 
000271 e40e                      			LDI R16, 'N'
000272 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU N VAO PAY_ADR + 15 (0X24F)
                                 
000273 e401                      			LDI R16, 'A'
000274 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU A VAO PAY_ADR + 16 (0X250)
                                 
000275 e408                      			LDI R16, 'H'
000276 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU H VAO PAY_ADR + 17 (0X251)
                                 
000277 e504                      			LDI R16, 'T'
000278 930d                      			ST X+, R16 ; LUU MA ASCII CUA CHU T VAO PAY_ADR + 18 (0X252)
                                 
000279 9508                      			RET
                                 
                                 ;----------------------------------------------------------------------------------------
                                 ; DIV3 CHIA SO NHI PHAN 24 BIT (GIA_TIEN) CHO 8 BIT (10), KET QUA LA SO 24 BIT
                                 ; CHIA BANG CACH TRU NHIEU LAN CHO SO CHIA
                                 
                                 ; INPUT: GIA_TIEN_HIGH:GIA_TIEN_MIDDLE:GIA_TIEN_LOW LA SO BI CHIA, SO CHIA = 10
                                 ; OUTPUT: GIA_TIEN_HIGH:GIA_TIEN_MIDDLE:GIA_TIEN_LOW LA THUONG SO 24 BIT, R16 LA DU SO
                                 
                                 ; SU DUNG R20, R21, R22 CHUA THUONG SO TAM THOI
                                 
                                 DIV3:
00027a 2744                      			CLR R20
00027b 2755                      			CLR R21
00027c 2766                      			CLR R22 ; CLEAR CAC THANH GHI CHUA THUONG SO TAM THOI
                                 LOOP:
00027d 9543                      			INC R20 ; TANG R20 LEN 1 DON VI
00027e f409                      			BRNE LP1 ; NEU R20 OVERFLOW TU 0XFF THANH 0X00, TANG R21 LEN 1 DON VI
00027f 9553                      			INC R21
                                 LP1:
000280 f409                      			BRNE LP2 ; NEU R21 OVERFLOW TU 0XFF THANH 0X00, TANG R22 LEN 1 DON VI
000281 9563                      			INC R22
                                 LP2:
000282 507a                      			SUBI GIA_TIEN_LOW, 10 ; TRU GIA_TIEN_LOW CHO 10
000283 f7c8                      			BRCC LOOP
                                 			; NEU GIA_TIEN_LOW < 10, (GIA_TIEN_LOW - 10) < 0, (GIA_TIEN_LOW - 10) SE BI TRAN, CARRY = 1, TRU GIA_TIEN_MIDDLE DI 1 DON VI (1 DON VI NAY LA CARRY)
                                 			; VD: GIA_TIEN_LOW = 0X09, (GIA_TIEN_LOW - 10) = 0XFF, LUC NAY TA SE TRU GIA TIEN MIDDLE DI 1 DON VI
000284 5081                      			SUBI GIA_TIEN_MIDDLE, 1
000285 f7b8                      			BRCC LOOP
                                 			; NEU (GIA_TIEN_MIDDLE - 1) BI TRAN, CARRY = 1, TRU GIA_TIEN_HIGH DI 1 DON VI (1 DON VI NAY LA CARRY)
000286 5091                      			SUBI GIA_TIEN_HIGH, 1
000287 f7a8                      			BRCC LOOP
                                 			; NEU (GIA_TIEN_HIGH - 1) BI TRAN, CARRY = 1, LUC NAY KHONG CHIA DUOC NUA VI SO DU BI AM (SO DU < 0), TA SE DI LAY LAI SO DU BANG CACH LAY SO DU BI AM + 10
                                 			; TRU THUONG SO TAM THOI R22:R21:R20 CHO 1 DE RA THUONG SO CHINH XAC, THUONG SO DUOC TANG THEM 1 O LAN TRU CUOI CUNG MA CARRY = 1
                                 
000288 e01a                      			LDI R17, 10
000289 24ff                      			CLR R15
                                 
00028a 0f71                      			ADD GIA_TIEN_LOW, R17 ; GIA_TIEN_LOW LUC NAY LA SO DU BI AM, (GIA_TIEN_LOW + 10) = SO DU NGAY TRUOC KHI CARRY = 1
                                 
00028b 5041                      			SUBI R20, 1 ; TRU 8 BIT THAP CUA THUONG SO VOI 1
00028c 4050                      			SBCI R21, 0 ; NEU 8 BIT THAP BI TRAN, TRU 8 BIT MIDDLE CHO 1 (SO 1 NAY LA CARRY)
00028d 4060                      			SBCI R22, 0 ; NEU 8 BIT MIDDLE BI TRAN, TRU 8 BIT CAO CHO 1 (SO 1 NAY LA CARRY)
                                 
00028e 2f07                      			MOV R16, GIA_TIEN_LOW ; CHUYEN SO DU VAO R16
                                 
00028f 2f74                      			MOV GIA_TIEN_LOW, R20
000290 2f85                      			MOV GIA_TIEN_MIDDLE, R21
000291 2f96                      			MOV GIA_TIEN_HIGH, R22 ; CHUYEN THUONG SO TAM THOI VAO LAI 3 THANH GHI GIA_TIEN DE CHUAN BI CHO LAN CHIA TIEP THEO
                                 
000292 9508                      			RET
                                 
                                 
                                 
                                 
                                 ;-----------------------------------------------------------------------------------
                                 ; DELAY_128US TAO DELAY BANG TIMER 1 CTC KENH A
                                 ; TIMER 1, CHIA 1024, MOI XUNG CHUA TRONG R16 LA 128US
                                 ; DELAY (128U X R16)s
                                 
                                 DELAY_128US:
000293 9300 0088                 			STS OCR1AL, R16 ; OCR1AL CHUA HET R16 NEN KHONG CAN XET DEN OCR1AH
000295 e000                      			LDI R16, 0X00
                                 
000296 9300 0080                 			STS TCCR1A, R16 ; TIMER 1
000298 e00d                      			LDI R16, 0X0D
000299 9300 0081                 			STS TCCR1B, R16 ; MODE CTC CHIA 1024 START
                                 OCF1A_FLAG_1:
